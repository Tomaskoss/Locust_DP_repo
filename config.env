# ══════════════════════════════════════════════
#  LOCUST 
# ══════════════════════════════════════════════
TARGET_HOST='https://google.sk'
USERS='1'
SPAWN_RATE='1'
RUN_TIME='5'
PROCESSES='-1'
TEST_TYPE='Load Test'

# Locust File testing scenario
LOCUST_FILE=Locustfile_http.py

# ══════════════════════════════════════════════
#  Network
# ══════════════════════════════════════════════
INTERFACE='ens33'
IP_START='192.168.10.40'
IP_END='192.168.10.80'
# ══════════════════════════════════════════════
#  REACHABILITY 
# ══════════════════════════════════════════════
REACH_INTERVAL='5'
REACH_TIMEOUT='5'
REACH_SRC_IP='192.168.10.40'
REACH_INTERFACE='ens33'
REACH_THRESHOLD='50'
IP_VERSION='ipv4'
IP6_START='fd00::10'
IP6_END='fd00::40'
IP6_PREFIX='fd00::/64'
IPV6_MODE='range'
